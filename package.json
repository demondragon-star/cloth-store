{
    "name": "clothes-monorepo",
    "version": "1.0.0",
    "private": true,
    "scripts": {
        "dev": "concurrently --kill-others-on-fail --names \"admin-web,bg-api\" --prefix-colors \"cyan,magenta\" \"npm run dev --prefix admin-web\" \"node scripts/start-python-api.js\"",
        "dev:web": "npm run dev --prefix admin-web",
        "dev:api": "node scripts/start-python-api.js",
        "start": "concurrently --kill-others-on-fail --names \"admin-web,bg-api\" --prefix-colors \"cyan,magenta\" \"npm run start --prefix admin-web\" \"node scripts/start-python-api.js\""
    },
    "devDependencies": {
        "concurrently": "^8.2.2"
    }
}
